# Resend email API
RESEND_API_KEY=your_resend_api_key_here

# Database — local development
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSL=false

# Database — production (Render)
# Set these in Render > Environment Variables. Use your hosted MySQL provider's values.
# DB_HOST=your-remote-host.example.com
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=your_db_name
# DB_SSL=true
