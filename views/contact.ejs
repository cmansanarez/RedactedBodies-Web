<!DOCTYPE html>
<html>
    <%- include('head', { title: 'Contact | Noir Mak', description: 'Get in touch with Noir Mak — open to exhibitions, residencies, commissions, and collaborative work.' }) %>

    <body>

        <%- include('header') %>

        <main>

            <!-- CONTACT HEADING -->
            <section id="contact-heading">
                <div class="container">
                    <div class="contact-header">
                        <h1 class="hero-title glitch-text">Transmit Signal</h1>
                        <p class="contact-subtitle">Open to exhibitions, residencies, commissions, and collaborative work. Based in Colorado. Operating remotely.</p>
                    </div>
                </div>
            </section>

            <!-- CONTACT FORM -->
            <section id="contact-form-section">
                <div class="container">

                    <!-- novalidate disables browser default validation so Bootstrap's custom UI shows instead -->
                    <form id="contact-form" class="needs-validation contact-form" novalidate>

                        <!-- NAME -->
                        <div class="row mb-4">
                            <div class="col">
                                <input type="text" id="name" class="form-control" placeholder="Full Name" required>
                                <div class="invalid-feedback">Don't be a stranger — we'll need your name.</div>
                            </div>
                        </div>

                        <!-- EMAIL -->
                        <div class="row mb-4">
                            <div class="col">
                                <input type="email" id="mail" class="form-control" placeholder="Email Address" required>
                                <div class="invalid-feedback">That signal's garbled — try name@example.com</div>
                            </div>
                        </div>

                        <!-- INQUIRY TYPE -->
                        <div class="row mb-4">
                            <div class="col">
                                <select id="inquiry-type" class="form-select" required>
                                    <option value="" disabled selected>Type of Inquiry</option>
                                    <option value="collaboration">Collaboration</option>
                                    <option value="commission">Commission</option>
                                    <option value="press">Press</option>
                                    <option value="general">General</option>
                                </select>
                                <div class="invalid-feedback">Pick a lane — what's this about?</div>
                            </div>
                        </div>

                        <!-- MESSAGE -->
                        <div class="row mb-4">
                            <div class="col">
                                <textarea id="msg" class="form-control" placeholder="Your Message" rows="6" required></textarea>
                                <div class="invalid-feedback">Don't be shy. Say something.</div>
                            </div>
                        </div>

                        <!-- SUBMIT -->
                        <div class="row">
                            <div class="col">
                                <button type="submit" id="contact-form-button" class="hero-btn">Send Transmission</button>
                            </div>
                        </div>

                        <div id="contact-button-response"></div>

                    </form>

                </div>
            </section>

        </main><!-- END MAIN -->

        <%- include('footer') %>
        <script type="module" src="./js/contact.js"></script>

    </body>

</html>
