<!DOCTYPE html>
<html>
    <%- include('head', { title: project.name + ' | Noir Mak', description: project.name + ' — a project by Noir Mak.' }) %>
    <body>

        <%- include('header') %>

        <main>

            <section id="project-detail">
                <div class="container">

                    <p class="featured-label">Project <%= project.id %></p>
                    <h1 class="hero-title"><%= project.name %></h1>

                    <div class="row mt-5 g-5">

                        <!-- IMAGE -->
                        <div class="col-lg-7">
                            <img src="/images/<%= project.image %>" alt="<%= project.name %>" class="featured-img">
                        </div>

                        <!-- DESCRIPTION + TAGS -->
                        <div class="col-lg-5">
                            <p class="project-detail-description"><%= project.description %></p>

                            <div class="project-tags">
                                <% project.tags.forEach((tag) => { %>
                                    <span class="project-tag"><%= tag %></span>
                                <% }) %>
                            </div>
                        </div>

                    </div>

                    <div class="project-detail-actions">
                        <a href="<%= project.url %>" class="hero-btn" target="_blank" rel="noopener noreferrer">Visit Project</a>
                        <a href="/projects" class="hero-btn">Back to Archive</a>
                    </div>

                </div>
            </section>

        </main>

        <%- include('footer') %>

    </body>
</html>
