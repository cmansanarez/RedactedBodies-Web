<!DOCTYPE html>
<html>
    <%- include('head', { title: 'Noir Mak', description: 'Noir Mak is the creative practice of Cam Mansanarez — a creative technologist and digital artist exploring queer identity, generative systems, glitch aesthetics, and live-coded performance. Portfolio, NFT collections, and exhibition archive.' }) %>

    <body>

        <%- include('header') %>

        <main>

            <!-- HERO SECTION -->
            <section id="hero">
                <div class="container">
                    <div class="hero-content">
                        <img src="./images/noirmak-logo-horizontal.png" alt="Noir Mak" class="hero-logo">
                        <p class="hero-tagline">generative art &bull; immersive systems &bull; creative technology</p>
                    </div>
                </div>
            </section><!-- END HERO -->

            <!-- FEATURED WORK SECTION -->
            <section id="featured">
                <div class="container">
                    <div class="row align-items-center">

                        <div class="col-lg-6">
                            <p class="featured-label">Featured Work</p>
                            <h2>Lumyn</h2>
                            <p class="featured-description">Lumyn: Constellation of Self is an interactive installation of poetry, projection, and collective light created by Noir Mak for FoCo Pride 2026. Using ml5.js motion tracking via webcam, the installation responds to gallery attendees in real time — transforming their physical presence into generative constellations of identity and belonging.</p>
                            <a href="https://visit-lumyn.noirmak.com/" class="hero-btn" target="_blank" rel="noopener noreferrer">Visit Lumyn</a>
                        </div>

                        <div class="col-lg-6">
                            <img src="./images/visit-lumyn-featured.jpg" alt="Lumyn: Constellation of Self" class="featured-img">
                        </div>

                    </div>
                </div>
            </section><!-- END FEATURED WORK -->

            <!-- NFT COLLECTION SECTION -->
            <section id="nft-collection">
                <div class="container">
                    <div class="row align-items-center">

                        <div class="col-lg-6">
                            <img src="./images/redacted-bodies-featured.png" alt="Redacted Bodies Collection" class="featured-img">
                        </div>

                        <div class="col-lg-6">
                            <p class="featured-label">NFT Collection</p>
                            <h2>Redacted Bodies</h2>
                            <p class="featured-description">A generative NFT collection exploring queer identity, censorship, synthetic memory, and digital permanence using a hand-crafted data set to train a local LoRA model, generative code, and Web3 infrastructure.</p>
                            <a href="/collection" class="hero-btn">Coming Soon — View Collection</a>
                        </div>

                    </div>
                </div>
            </section><!-- END NFT COLLECTION -->

            <!-- ABOUT SECTION -->
            <section id="about">
                <div class="container">
                    <div class="about-card">
                        <p class="featured-label">The Artist</p>
                        <h2 class="glitch-text">Cam Mansanarez / Noir Mak</h2>
                        <p class="about-text">Cam Mansanarez, known artistically as Noir Mak, is a creative technologist and digital artist whose work explores queerness, identity, and the tension between human vulnerability and machine precision. Based in Colorado, Cam creates immersive visual worlds that merge generative systems, glitch aesthetics, and cyberpunk atmosphere. His practice spans live-coded performance, web-based interactive art, and computational installations that transform code into spaces of reflection, resistance, and transformation.</p>
                        <p class="about-text">Cam fuses abstraction with queer futurism to challenge traditional notions of visibility and beauty. He works with the belief that digital tools can become vessels for empowerment and self-invention, especially for marginalized communities. Through his pseudonym Noir Mak, he shapes experiences that feel both intimate and otherworldly, celebrating the radical act of being seen.</p>
                        <p class="about-text">Cam is currently completing his master's degree in Creative Technology, focusing on generative art, interactive systems, and the creative potential of emerging technologies. His recent work includes Hydra-driven live visuals, Processing-based generative animations, and browser-native art that blends data, poetry, and glitch.</p>
                        <p class="about-text">As Noir Mak, he creates art that carries rebellion and tenderness in equal measure. His work honors the poetry of glitch, the softness inside cyber aesthetics, and the idea that transformation often begins in the shadows before it becomes luminous.</p>
                        <div class="text-center mt-4">
                            <a href="/contact" class="hero-btn">Contact the Artist</a>
                        </div>
                    </div>
                </div>
            </section><!-- END ABOUT -->

            <!-- ARCHIVE SECTION -->
            <section id="archive">
                <div class="container">
                    <p class="featured-label">Archive</p>
                    <h2 class="archive-title">The Archive</h2>
                    <% const accents = ['card-accent-1', 'card-accent-2', 'card-accent-3', 'card-accent-4']; %>
                    <div class="row g-4">

                        <% projectArray.forEach((item, index) => { %>
                        <div class="col-lg-4 col-md-6 project-card-wrapper" style="--card-delay: <%= index * 0.08 %>s">
                            <div class="card project-card <%= accents[index % 4] %>">
                                <img src="/images/<%= item.image %>" class="card-img" alt="<%= item.name %>">
                                <div class="card-img-overlay d-flex align-items-end">
                                    <h5 class="project-title">
                                        <a href="/project/<%= item.id %>" class="stretched-link"><%= item.name %></a>
                                    </h5>
                                </div>
                            </div>
                        </div>
                        <% }) %>

                    </div><!-- END ROW -->
                </div><!-- END CONTAINER -->
            </section><!-- END ARCHIVE -->

            <!-- LIVE CODING SECTION -->
            <section id="live-coding">
                <div class="container">

                    <p class="featured-label">Live Performance</p>
                    <h2 class="section-title">Live Coding</h2>

                    <!-- Description + Featured Video -->
                    <div class="row align-items-center mb-5">

                        <div class="col-lg-6">
                            <p class="live-coding-text">Cam performs live using hand-coded visuals built in Hydra Video Synth — a browser-based, JavaScript/WebGL live coding environment for real-time visual composition. His performances are fully audio-reactive, responding to sound in real time to produce immersive, glitch-driven visual landscapes that exist only in the moment of performance.</p>
                            <p class="live-coding-text">Signal Bloom is his capstone project: a modular AI-assisted live visual performance environment merging Hydra live coding, generative AI imagery using ComfyUI, and audio-reactive systems into a unified performance instrument. The work investigates the evolving relationship between performer, machine, and emergence.</p>
                            <a href="https://github.com/cmansanarez/Signal_Bloom/blob/main/README.md" class="hero-btn" target="_blank">Work In Progress - View Signal Bloom Repo</a>
                        </div>

                        <div class="col-lg-6">
                            <div class="video-embed">
                                <div class="ratio ratio-16x9">
                                    <iframe src="https://www.youtube.com/embed/zqkRFfcOIhc" title="Live Coding Performance — Noir Mak" allowfullscreen></iframe>
                                </div>
                            </div>
                        </div>

                    </div><!-- END ROW -->

                    <!-- Performance Image Gallery -->
                    <div class="row g-3">
                        <div class="col-lg-4 col-md-6 gallery-accent-blue">
                            <img src="./images/noirmak-website-livcoding-left.jpg" class="live-gallery-img" alt="Live Coding Performance">
                        </div>
                        <div class="col-lg-4 col-md-6 gallery-accent-yellow">
                            <img src="./images/noirmak-website-livcoding-center.jpg" class="live-gallery-img" alt="Live Coding Performance">
                        </div>
                        <div class="col-lg-4 col-md-6 gallery-accent-green">
                            <img src="./images/noirmak-website-livcoding-right.jpg" class="live-gallery-img" alt="Live Coding Performance">
                        </div>
                    </div><!-- END GALLERY ROW -->

                </div><!-- END CONTAINER -->
            </section><!-- END LIVE CODING -->

            <!-- SHOWS SECTION -->
            <section id="shows">
                <div class="container">

                    <p class="featured-label">Exhibitions & Performances</p>
                    <h2 class="section-title">Shows</h2>

                    <div class="shows-timeline">

                        <!-- 2026 -->
                        <div class="shows-year-group">
                            <div class="shows-year-heading">
                                <div class="shows-year-dot"></div>
                                <span class="shows-year">2026</span>
                            </div>

                            <div class="shows-entry">
                                <p class="shows-title"><a href="https://visit-lumyn.noirmak.com/" target="_blank">"Lumyn: Constellation of Self"</a></p>
                                <p class="shows-meta">Interactive Art Installation · Center for Creativity, Fort Collins, CO</p>
                                <p class="shows-meta">As part of NoCo Pride Festival 2026</p>
                                <p class="shows-meta">June 3 – 7, 2026</p>
                            </div>
                            <hr class="shows-divider">

                            <div class="shows-entry">
                                <p class="shows-title">Generative Visuals</p>
                                <p class="shows-meta">Winched Album Release Party · Collective Vintage, Fort Collins, CO</p>
                                <p class="shows-meta">May 16, 2026</p>
                            </div>
                            <hr class="shows-divider">

                            <div class="shows-entry">
                                <p class="shows-title">Live Coding Visuals</p>
                                <p class="shows-meta">Dust Cuts Vinyl Night v6 · Mirus Art Gallery, Denver, CO</p>
                                <p class="shows-meta">May 1, 2026</p>
                            </div>
                            <hr class="shows-divider">

                            <div class="shows-entry">
                                <p class="shows-title">Live Coding Visuals</p>
                                <p class="shows-meta">The DMV, Denver, CO</p>
                                <p class="shows-meta">January 18, 2026</p>
                            </div>
                            <hr class="shows-divider">

                            <div class="shows-entry">
                                <p class="shows-title">Live Coding Visuals</p>
                                <p class="shows-meta">NoCo Noise Floor No. 36 · Museum of Art Fort Collins, CO</p>
                                <p class="shows-meta">January 17, 2026</p>
                            </div>
                        </div><!-- END 2026 -->

                        <!-- 2025 -->
                        <div class="shows-year-group">
                            <div class="shows-year-heading">
                                <div class="shows-year-dot"></div>
                                <span class="shows-year">2025</span>
                            </div>

                            <div class="shows-entry">
                                <p class="shows-title"><a href="https://grayareaorg.github.io/creative-code-exhibition-fall-2025/" target="_blank">"Lumyn: A Hymn of Self"</a></p>
                                <p class="shows-meta">Gray Area Creative Code Showcase · Online, Remote</p>
                                <p class="shows-meta">December 15, 2025</p>
                            </div>
                            <hr class="shows-divider">

                            <div class="shows-entry">
                                <p class="shows-title">Live Coding Visuals</p>
                                <p class="shows-meta">NoCo Noise Floor No. 34 · Museum of Art Fort Collins, CO</p>
                                <p class="shows-meta">November 22, 2025</p>
                            </div>
                        </div><!-- END 2025 -->

                    </div><!-- END SHOWS TIMELINE -->

                </div><!-- END CONTAINER -->
            </section><!-- END SHOWS -->

        </main><!-- END MAIN -->

        <%- include('footer') %>

        <!-- PAGE-SPECIFIC SCRIPTS -->
        <script src="https://unpkg.com/hydra-synth"></script>
        <script src="./js/hero-sketch.js"></script>
        <script src="./js/hydra-sketch.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/p5@1.9.4/lib/p5.min.js"></script>
        <script src="./js/archive-sketch.js"></script>
        <script type="module" src="./js/index.js"></script>

    </body>

</html>
