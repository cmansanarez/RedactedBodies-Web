<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta http-equiv="content-type" content="text/html; charset=utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" type="image/png" href="/images/rb-favicon.png">
        <title>Archive | Noir Mak</title>
        <meta name="author" content="Cam Mansanarez | Noir Mak">
        <meta name="description" content="The Archive — a complete record of projects by Noir Mak spanning generative art, live coding, interactive installations, and web-based work.">

        <!-- GOOGLE FONTS -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400&family=Space+Grotesk:wght@400&family=Space+Mono&family=Syne:wght@800&display=swap" rel="stylesheet">

        <!-- BOOTSTRAP -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

        <!-- STYLESHEET -->
        <link rel="stylesheet" href="/css/style.css">

    </head>
    <body>

        <%- include('header') %>

        <main>

            <!-- PROJECTS BANNER -->
            <section id="projects-banner">
                <div class="container">
                    <p class="featured-label">Projects</p>
                    <h1 class="hero-title">The Archive</h1>
                </div>
            </section>

            <!-- PROJECTS GRID -->
            <section id="projects-grid">
                <div class="container">
                    <% const accents = ['card-accent-1', 'card-accent-2', 'card-accent-3', 'card-accent-4']; %>
                    <div class="row g-4">
                        <% projectArray.forEach((item, index) => { %>
                            <div class="col-lg-4 col-md-6">
                                <div class="card project-card <%= accents[index % 4] %>">
                                    <img src="/images/<%= item.image %>" class="card-img" alt="<%= item.name %>">
                                    <div class="card-img-overlay d-flex align-items-end">
                                        <h5 class="project-title">
                                            <a href="/project/<%= index + 1 %>" class="stretched-link"><%= item.name %></a>
                                        </h5>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>

        </main>

        <%- include('footer') %>

    </body>
</html>
